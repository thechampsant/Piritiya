# AWS Configuration for Piritiya
# Copy this file to .env and update with your values

# AWS Region (Mumbai, India)
AWS_REGION=ap-south-1

# AWS Credentials (get from AWS Console → IAM)
AWS_ACCESS_KEY_ID=your-access-key-here
AWS_SECRET_ACCESS_KEY=your-secret-key-here

# S3 Buckets
S3_BUCKET_DATA=piritiya-data
S3_BUCKET_KNOWLEDGE_BASE=piritiya-knowledge-base

# DynamoDB Tables
DYNAMODB_TABLE_FARMERS=Farmers
DYNAMODB_TABLE_NISAR=NISARData
DYNAMODB_TABLE_CROP_RECOMMENDATIONS=CropRecommendations
DYNAMODB_TABLE_CONSULTATIONS=Consultations

# Bedrock Configuration
BEDROCK_AGENT_ID=your-agent-id-here
BEDROCK_AGENT_ALIAS_ID=your-alias-id-here
KNOWLEDGE_BASE_ID=your-kb-id-here

# Lambda Functions
LAMBDA_SOIL_MOISTURE=get-soil-moisture
LAMBDA_CROP_ADVICE=get-crop-advice
LAMBDA_MARKET_PRICES=get-market-prices

# Redis Configuration (for Phase 2)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Celery Configuration (for Phase 2)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# FastAPI Configuration (for Phase 2)
API_PORT=8000
DEBUG=True

# JWT Configuration (for Phase 2)
JWT_SECRET=your-jwt-secret-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION=7d

# Piritiya FastAPI Backend - AWS Lambda container image
# Use with API Gateway HTTP API (payload 2.0). Handler: lambda_handler.handler
FROM public.ecr.aws/lambda/python:3.11

WORKDIR /var/task

# Install dependencies (slim list for Lambda)
COPY requirements-lambda.txt .
RUN pip install --no-cache-dir -r requirements-lambda.txt

# Copy application
COPY main.py .
COPY lambda_handler.py .

# Lambda handler is set by CMD; override in AWS if needed
CMD ["lambda_handler.handler"]
